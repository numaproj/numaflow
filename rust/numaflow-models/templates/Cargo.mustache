[package]
name = "numaflow-models"
version = "0.0.0-pre"
authors = ["The Numaproj Authors"]
description = "Numaflow models"
license = "Apache-2.0 license"
edition = "2024"

[dependencies]
k8s-openapi = { version = "0.27.1", features = ["v1_34"] }
kube.workspace = true
serde_json.workspace = true
serde_derive = "^1.0"
url = "^2.2"

[dependencies.reqwest]
version = "^0.13"
default-features = false
features = ["json", "multipart", "rustls"]
